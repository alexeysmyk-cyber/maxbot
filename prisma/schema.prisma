// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

//
// ===== ENUM ROLES =====
//

enum RoleKey {
  ADMIN
  DOCTOR
  MANAGER
  CALL_CENTER
  CASHIER
  NURSE
  HEAD_NURSE
  HEAD_MANAGER
  HEAD_CALL_CENTER
  HEAD_DOCTOR
  ACCOUNTANT
  SYSTEM_ADMINISTRATOR
  PATIENT
}

//
// ===== USER =====
//

model User {
  id        Int    @id @default(autoincrement())
  vk_id     String @unique
  email     String?
  mis_id    String?
  name      String?

  type      String?   // EMPLOYEE / PATIENT
  activeRole String?  // для будущего переключения ролей

  roles     UserRole[]
  overrides UserPermissionOverride[]
notifications UserNotification[]
  
  alerts UpcomingVisitAlert[]

  createdAt DateTime @default(now())
  
}

//
// ===== ROLE =====
//

model Role {
  id    Int     @id @default(autoincrement())
  key   RoleKey @unique
  name  String
mis_code String? 
  users       UserRole[]
  permissions RolePermission[]
  roleNotifications RoleNotification[]
}

//
// ===== USER ↔ ROLE =====
//

model UserRole {
  id     Int @id @default(autoincrement())
  userId Int
  roleId Int
  mis_code String? 
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

//
// ===== PERMISSIONS =====
//

model Permission {
  id   Int    @id @default(autoincrement())
  key  String @unique
  name String

  roles RolePermission[]
  users UserPermissionOverride[]
}

//
// ===== ROLE → PERMISSION =====
//

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int
  permissionId Int

role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

//
// ===== USER OVERRIDE =====
//

model UserPermissionOverride {
  id           Int @id @default(autoincrement())
  userId       Int
  permissionId Int
  allowed      Boolean

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

model AuthCode {
  id        Int      @id @default(autoincrement())
  email     String?
  phone     String?   // 👈 есть
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model VkSession {
  id        Int      @id @default(autoincrement())
  vk_id     String   @unique
  step      String
  data      Json?
  updatedAt DateTime @updatedAt
}

model NotificationType {
  id       Int    @id @default(autoincrement())
  key      String @unique
  name     String
  modeType String // TRIPLE | BOOLEAN
userSettings UserNotification[]
  roles    RoleNotification[]
}

model RoleNotification {
  id       Int @id @default(autoincrement())

  roleId   Int
  typeId   Int

  defaultMode String // default значение

role     Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
type     NotificationType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([roleId, typeId])
}

model UserNotification {
  id     Int @id @default(autoincrement())

  userId Int
  typeId Int

  mode   String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType @relation(fields: [typeId], references: [id])

  @@unique([userId, typeId])
}

model UpcomingVisitAlert {
  id        Int      @id @default(autoincrement())

  userId    Int
  mode      String   // self | all
  type     String 
  time      String   // "07:00"
  enabled   Boolean  @default(true)
  lastSent  DateTime?

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}